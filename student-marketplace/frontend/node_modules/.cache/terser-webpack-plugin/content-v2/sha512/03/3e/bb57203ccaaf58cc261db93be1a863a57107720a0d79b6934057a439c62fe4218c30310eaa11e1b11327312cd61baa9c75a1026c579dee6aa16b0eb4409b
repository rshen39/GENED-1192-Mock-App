AAE0C,QAAS,CAAArJ,QAAA,CAAC,SAEhE,CAAQ,CAAC,cAETF,0BAAA,CAACI,gCAAI,EAACC,EAAE,CAAC,OAAO,CAAAH,QAAA,CAAC,OAAK,CAAM,CAC7B,EACE,CAAC,EACH,CAAC,CACA,CAAC,CAEb,CAEeoJ,4DAAM,E;;AC1BrB,QAAS,CAAAE,MAAMA,CAAA,CAAG,CAChB,mBACExJ,0BAAA,WAAQC,SAAS,CAAC,aAAa,CAAAC,QAAA,cAC7BC,2BAAA,QAAKF,SAAS,CAAC,eAAe,CAAAC,QAAA,eAC5BF,0BAAA,WAAAE,QAAA,CAAQ,qBAAmB,CAAQ,CAAC,cACpCF,0BAAA,MAAGC,SAAS,CAAC,OAAO,CAAAC,QAAA,CAAC,6EAErB,CAAG,CAAC,EACD,CAAC,CACA,CAAC,CAEb,CAEesJ,4DAAM,E;;ACLrB,QAAS,CAAAC,GAAGA,CAAA,CAAG,CACb,KAAM,CAAC1J,WAAW,CAAE2J,cAAc,CAAC,CAAGrF,yBAAQ,CAAC,IAAMzC,gBAAgB,CAAC,CAAC,CAAC,CAExE,QAAS,CAAA+H,YAAYA,CAAA,CAAG,CACtBpH,YAAY,CAAC,CAAC,CACdmH,cAAc,CAAC,IAAI,CAAC,CACtB,CAEA,mBACE1J,0BAAA,CAAC4J,yCAAM,EAAA1J,QAAA,cACLC,2BAAA,QAAKF,SAAS,CAAC,WAAW,CAAAC,QAAA,eACxBF,0BAAA,CAACsJ,iBAAM,EAACvJ,WAAW,CAAEA,WAAY,CAACwJ,QAAQ,CAAEI,YAAa,CAAE,CAAC,cAC5DxJ,2BAAA,CAAC0J,8BAAM,EAAA3J,QAAA,eACLF,0BAAA,CAAC8J,6BAAK,EAACC,IAAI,CAAC,GAAG,CAACC,KAAK,MAAA9J,QAAA,cACnBF,0BAAA,CAACH,UAAI,EAACE,WAAW,CAAEA,WAAY,CAAE,CAAC,CAC7B,CAAC,cACRC,0BAAA,CAAC8J,6BAAK,EAACC,IAAI,CAAC,WAAW,CAAA7J,QAAA,cACrBF,0BAAA,CAACkE,cAAQ,EAACnE,WAAW,CAAEA,WAAY,CAAE,CAAC,CACjC,CAAC,cACRC,0BAAA,CAAC8J,6BAAK,EAACC,IAAI,CAAC,UAAU,CAAA7J,QAAA,cACpBF,0BAAA,CAACsH,iBAAW,EAACvH,WAAW,CAAEA,WAAY,CAAE,CAAC,CACpC,CAAC,cACRC,0BAAA,CAAC8J,6BAAK,EAACC,IAAI,CAAC,OAAO,CAAA7J,QAAA,cACjBF,0BAAA,CAACgI,UAAI,EAACC,OAAO,CAAEyB,cAAe,CAAE,CAAC,CAC5B,CAAC,EACF,CAAC,cACT1J,0BAAA,CAACwJ,iBAAM,GAAE,CAAC,EACP,CAAC,CACA,CAAC,CAEb,CAEeC,+CAAG,E;;;;;ACrClBQ,mBAAQ,CAACC,MAAM,cACblK,0BAAA,CAACmK,eAAK,CAACC,UAAU,EAAAlK,QAAA,cACfF,0BAAA,CAACyJ,OAAG,GAAE,CAAC,CACS,CAAC,CACnBY,QAAQ,CAACC,cAAc,CAAC,MAAM,CAChC,CAAC,C","file":"x","sourcesContent":["// extracted by mini-css-extract-plugin","import React from 'react';\nimport { Link } from 'react-router-dom';\n\nfunction Home({ currentUser }) {\n  return (\n    <main className=\"page\">\n      <section className=\"hero\">\n        <div className=\"panel hero-copy\">\n          <span className=\"eyebrow\">Campus resale network</span>\n          <h1>Move out lighter. Sell faster.</h1>\n          <p className=\"lede\">\n            A simple marketplace for students trading dorm gear, furniture, and essentials before the term ends.\n          </p>\n          <div className=\"button-row\">\n            <Link className=\"button\" to=\"/listings\">\n              Browse listings\n            </Link>\n            {currentUser ? (\n              <Link className=\"button-secondary\" to=\"/profile\">\n                View your profile\n              </Link>\n            ) : (\n              <Link className=\"button-secondary\" to=\"/auth\">\n                Create account\n              </Link>\n            )}\n          </div>\n        </div>\n        <aside className=\"panel hero-card\">\n          <div className=\"hero-stat\">\n            <strong>2</strong>\n            <span>Sample listings loaded at startup</span>\n          </div>\n          <div className=\"hero-stat\">\n            <strong>File-backed API</strong>\n            <span>No MongoDB dependency required to boot this app</span>\n          </div>\n          <div className=\"hero-stat\">\n            <strong>Fast filters</strong>\n            <span>Search by school, region, area, location, keyword, and category from the listings page</span>\n          </div>\n        </aside>\n      </section>\n    </main>\n  );\n}\n\nexport default Home;\n","import axios from 'axios';\n\nconst API_BASE_URL = 'http://localhost:5001/api';\nconst SESSION_KEY = 'student-marketplace-session';\n\nexport const fetchListings = async (params = {}) => {\n  try {\n    const response = await axios.get(`${API_BASE_URL}/listings`, { params });\n    return response.data;\n  } catch (error) {\n    console.error('Error fetching listings:', error);\n    throw error;\n  }\n};\n\nexport const createListing = async (listingData) => {\n  try {\n    const response = await axios.post(`${API_BASE_URL}/listings`, listingData);\n    return response.data;\n  } catch (error) {\n    console.error('Error creating listing:', error);\n    throw error;\n  }\n};\n\nexport const fetchUserProfile = async (userId) => {\n  try {\n    const response = await axios.get(`${API_BASE_URL}/users/${userId}`);\n    return response.data;\n  } catch (error) {\n    console.error('Error fetching user profile:', error);\n    throw error;\n  }\n};\n\nexport const registerAccount = async (userData) => {\n  try {\n    const response = await axios.post(`${API_BASE_URL}/users`, userData);\n    return response.data;\n  } catch (error) {\n    console.error('Error creating account:', error);\n    throw error;\n  }\n};\n\nexport const loginAccount = async (credentials) => {\n  try {\n    const response = await axios.post(`${API_BASE_URL}/auth/login`, credentials);\n    return response.data;\n  } catch (error) {\n    console.error('Error logging in:', error);\n    throw error;\n  }\n};\n\nexport const getStoredSession = () => {\n  const stored = window.localStorage.getItem(SESSION_KEY);\n  return stored ? JSON.parse(stored) : null;\n};\n\nexport const storeSession = (user) => {\n  window.localStorage.setItem(SESSION_KEY, JSON.stringify(user));\n};\n\nexport const clearSession = () => {\n  window.localStorage.removeItem(SESSION_KEY);\n};\n\nexport const formatPrice = (price) => {\n  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(price);\n};\n","import React from 'react';\nimport { formatPrice } from '../utils';\n\nfunction ListingCard({ listing }) {\n  return (\n    <article className=\"listing-card\">\n      {listing.imageData ? (\n        <img className=\"listing-image\" src={listing.imageData} alt={listing.title} />\n      ) : (\n        <div className=\"listing-image listing-image-placeholder\">No photo uploaded</div>\n      )}\n      <div className=\"listing-meta\">\n        <span className=\"tag\">{listing.category}</span>\n        <span className=\"price-pill\">{formatPrice(listing.price)}</span>\n      </div>\n      <h3>{listing.title}</h3>\n      <p className=\"muted\">{listing.description}</p>\n      <div className=\"listing-meta\">\n        <span>{listing.location}</span>\n        <span>{listing.seller ? listing.seller.username : 'Unknown seller'}</span>\n      </div>\n      <p className=\"muted listing-region\">\n        {[listing.school, listing.region, listing.area].filter(Boolean).join(' • ')}\n      </p>\n    </article>\n  );\n}\n\nexport default ListingCard;\n","import React, { useEffect, useMemo, useState } from 'react';\nimport { Link } from 'react-router-dom';\nimport ListingCard from '../components/ListingCard';\nimport { createListing, fetchListings } from '../utils';\n\nconst initialForm = {\n  title: '',\n  description: '',\n  price: '',\n  category: 'General',\n  location: '',\n  school: '',\n  region: '',\n  area: '',\n  imageData: '',\n};\n\nfunction Listings({ currentUser }) {\n  const [listings, setListings] = useState([]);\n  const [filters, setFilters] = useState({ q: '', location: '', category: '', school: '', region: '', area: '' });\n  const [form, setForm] = useState(initialForm);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState('');\n  const [status, setStatus] = useState('');\n\n  useEffect(() => {\n    if (!currentUser) {\n      setForm(initialForm);\n      return;\n    }\n\n    setForm((current) => ({\n      ...current,\n      school: current.school || currentUser.school || '',\n      region: current.region || currentUser.region || '',\n      area: current.area || currentUser.area || '',\n    }));\n  }, [currentUser]);\n\n  useEffect(() => {\n    let active = true;\n\n    async function loadListings() {\n      setLoading(true);\n      setError('');\n      try {\n        const data = await fetchListings(filters);\n        if (active) {\n          setListings(data);\n        }\n      } catch (err) {\n        if (active) {\n          setError('Unable to load listings. Start the backend on port 5000.');\n        }\n      } finally {\n        if (active) {\n          setLoading(false);\n        }\n      }\n    }\n\n    loadListings();\n    return () => {\n      active = false;\n    };\n  }, [filters]);\n\n  const listingCountLabel = useMemo(() => {\n    if (loading) {\n      return 'Loading listings...';\n    }\n    return `${listings.length} listing${listings.length === 1 ? '' : 's'} found`;\n  }, [listings.length, loading]);\n\n  async function handleSubmit(event) {\n    event.preventDefault();\n    setStatus('');\n    setError('');\n\n    if (!currentUser) {\n      setError('Create an account or log in before posting a listing.');\n      return;\n    }\n\n    try {\n      await createListing({\n        ...form,\n        price: Number(form.price),\n        sellerId: currentUser.id,\n      });\n      setForm({\n        ...initialForm,\n        school: currentUser.school || '',\n        region: currentUser.region || '',\n        area: currentUser.area || '',\n      });\n      setStatus('Listing created.');\n      const data = await fetchListings(filters);\n      setListings(data);\n    } catch (err) {\n      setError('Unable to create listing. Check the form fields and backend status.');\n    }\n  }\n\n  function handleImageUpload(event) {\n    const file = event.target.files?.[0];\n\n    if (!file) {\n      setForm((current) => ({ ...current, imageData: '' }));\n      return;\n    }\n\n    const reader = new FileReader();\n    reader.onload = () => {\n      setForm((current) => ({ ...current, imageData: String(reader.result || '') }));\n    };\n    reader.readAsDataURL(file);\n  }\n\n  return (\n    <main className=\"page\">\n      <section className=\"panel section\">\n        <span className=\"eyebrow\">Marketplace feed</span>\n        <h2 className=\"section-title\">Listings</h2>\n        <p className=\"muted\">{listingCountLabel}</p>\n        <div className=\"toolbar\">\n          <div className=\"field\">\n            <label htmlFor=\"search\">Search</label>\n            <input\n              id=\"search\"\n              value={filters.q}\n              onChange={(event) => setFilters((current) => ({ ...current, q: event.target.value }))}\n              placeholder=\"fridge, lamp, textbook\"\n            />\n          </div>\n          <div className=\"field\">\n            <label htmlFor=\"location\">Location</label>\n            <input\n              id=\"location\"\n              value={filters.location}\n              onChange={(event) => setFilters((current) => ({ ...current, location: event.target.value }))}\n              placeholder=\"Cambridge\"\n            />\n          </div>\n          <div className=\"field\">\n            <label htmlFor=\"category\">Category</label>\n            <select\n              id=\"category\"\n              value={filters.category}\n              onChange={(event) => setFilters((current) => ({ ...current, category: event.target.value }))}\n            >\n              <option value=\"\">All categories</option>\n              <option value=\"Appliances\">Appliances</option>\n              <option value=\"Furniture\">Furniture</option>\n              <option value=\"General\">General</option>\n            </select>\n          </div>\n          <div className=\"field\">\n            <label htmlFor=\"school\">School</label>\n            <input\n              id=\"school\"\n              value={filters.school}\n              onChange={(event) => setFilters((current) => ({ ...current, school: event.target.value }))}\n              placeholder=\"Harvard University\"\n            />\n          </div>\n          <div className=\"field\">\n            <label htmlFor=\"region\">Region</label>\n            <input\n              id=\"region\"\n              value={filters.region}\n              onChange={(event) => setFilters((current) => ({ ...current, region: event.target.value }))}\n              placeholder=\"Greater Boston\"\n            />\n          </div>\n          <div className=\"field\">\n            <label htmlFor=\"area\">General area</label>\n            <input\n              id=\"area\"\n              value={filters.area}\n              onChange={(event) => setFilters((current) => ({ ...current, area: event.target.value }))}\n              placeholder=\"Harvard Square\"\n            />\n          </div>\n          <div className=\"button-row\">\n            <button\n              className=\"button-secondary\"\n              type=\"button\"\n              onClick={() => setFilters({ q: '', location: '', category: '', school: '', region: '', area: '' })}\n            >\n              Reset filters\n            </button>\n          </div>\n        </div>\n\n        {error ? <div className=\"status error\">{error}</div> : null}\n        {status ? <div className=\"status success\">{status}</div> : null}\n\n        <div className=\"cards\" style={{ marginTop: 20 }}>\n          {!loading && listings.length === 0 ? (\n            <div className=\"empty-state\">No listings match the current filters.</div>\n          ) : null}\n          {listings.map((listing) => (\n            <ListingCard key={listing.id} listing={listing} />\n          ))}\n        </div>\n      </section>\n\n      <section className=\"panel section\">\n        <span className=\"eyebrow\">Create listing</span>\n        <h2 className=\"section-title\">Post something for sale</h2>\n        {!currentUser ? (\n          <div className=\"status error\">\n            You need an account to post. <Link to=\"/auth\">Create one or log in here.</Link>\n          </div>\n        ) : null}\n        <form className=\"form-grid\" onSubmit={handleSubmit}>\n          <div className=\"field\">\n            <label htmlFor=\"title\">Title</label>\n            <input\n              id=\"title\"\n              value={form.title}\n              onChange={(event) => setForm((current) => ({ ...current, title: event.target.value }))}\n              required\n            />\n          </div>\n          <div className=\"field\">\n            <label htmlFor=\"description\">Description</label>\n            <textarea\n              id=\"description\"\n              value={form.description}\n              onChange={(event) => setForm((current) => ({ ...current, description: event.target.value }))}\n              required\n            />\n          </div>\n          <div className=\"toolbar\">\n            <div className=\"field\">\n              <label htmlFor=\"price\">Price</label>\n              <input\n                id=\"price\"\n                type=\"number\"\n                min=\"0\"\n                step=\"0.01\"\n                value={form.price}\n                onChange={(event) => setForm((current) => ({ ...current, price: event.target.value }))}\n                required\n              />\n            </div>\n            <div className=\"field\">\n              <label htmlFor=\"form-category\">Category</label>\n              <select\n                id=\"form-category\"\n                value={form.category}\n                onChange={(event) => setForm((current) => ({ ...current, category: event.target.value }))}\n              >\n                <option value=\"General\">General</option>\n                <option value=\"Appliances\">Appliances</option>\n                <option value=\"Furniture\">Furniture</option>\n              </select>\n            </div>\n            <div className=\"field\">\n              <label htmlFor=\"form-location\">Location</label>\n              <input\n                id=\"form-location\"\n                value={form.location}\n                onChange={(event) => setForm((current) => ({ ...current, location: event.target.value }))}\n                required\n              />\n            </div>\n            <div className=\"field\">\n              <label htmlFor=\"form-school\">School</label>\n              <input\n                id=\"form-school\"\n                value={form.school}\n                onChange={(event) => setForm((current) => ({ ...current, school: event.target.value }))}\n                placeholder=\"Your school\"\n              />\n            </div>\n            <div className=\"field\">\n              <label htmlFor=\"form-region\">Region</label>\n              <input\n                id=\"form-region\"\n                value={form.region}\n                onChange={(event) => setForm((current) => ({ ...current, region: event.target.value }))}\n                placeholder=\"Your region\"\n              />\n            </div>\n            <div className=\"field\">\n              <label htmlFor=\"form-area\">General area</label>\n              <input\n                id=\"form-area\"\n                value={form.area}\n                onChange={(event) => setForm((current) => ({ ...current, area: event.target.value }))}\n                placeholder=\"Neighborhood or square\"\n              />\n            </div>\n            <div className=\"field\">\n              <label htmlFor=\"form-image\">Photo</label>\n              <input id=\"form-image\" type=\"file\" accept=\"image/*\" onChange={handleImageUpload} />\n            </div>\n          </div>\n          {form.imageData ? <img className=\"listing-preview\" src={form.imageData} alt=\"Listing preview\" /> : null}\n          <div className=\"button-row\">\n            <button className=\"button\" type=\"submit\" disabled={!currentUser}>\n              Publish listing\n            </button>\n          </div>\n        </form>\n      </section>\n    </main>\n  );\n}\n\nexport default Listings;\n","import React, { useEffect, useState } from 'react';\nimport { Link } from 'react-router-dom';\nimport ListingCard from '../components/ListingCard';\nimport { fetchUserProfile } from '../utils';\n\nfunction UserProfile({ currentUser }) {\n  const [profile, setProfile] = useState(null);\n  const [error, setError] = useState('');\n\n  useEffect(() => {\n    if (!currentUser) {\n      setProfile(null);\n      setError('');\n      return undefined;\n    }\n\n    let active = true;\n\n    async function loadProfile() {\n      try {\n        const data = await fetchUserProfile(currentUser.id);\n        if (active) {\n          setProfile(data);\n        }\n      } catch (err) {\n        if (active) {\n          setError('Unable to load the demo profile. Start the backend on port 5000.');\n        }\n      }\n    }\n\n    loadProfile();\n    return () => {\n      active = false;\n    };\n  }, [currentUser]);\n\n  return (\n    <main className=\"page\">\n      <section className=\"panel section\">\n        <span className=\"eyebrow\">Seller profile</span>\n        <h2 className=\"section-title\">Profile</h2>\n        {!currentUser ? (\n          <div className=\"status error\">\n            Sign in first to see your profile. <Link to=\"/auth\">Go to login.</Link>\n          </div>\n        ) : null}\n        {error ? <div className=\"status error\">{error}</div> : null}\n        {currentUser && !profile ? (\n          <p className=\"muted\">Loading profile...</p>\n        ) : profile ? (\n          <div className=\"profile-grid\">\n            <div>\n              <h3>{profile.username}</h3>\n              <p className=\"muted\">{profile.email}</p>\n              <p>{profile.bio || 'No bio provided.'}</p>\n              <span className=\"tag\">{profile.campus || 'Campus not set'}</span>\n              <div className=\"profile-details\">\n                <span className=\"tag\">{profile.school || 'School not set'}</span>\n                <span className=\"tag\">{profile.region || 'Region not set'}</span>\n                <span className=\"tag\">{profile.area || 'Area not set'}</span>\n              </div>\n            </div>\n            <div>\n              <h3>Active listings</h3>\n              <div className=\"cards\">\n                {profile.listings.length === 0 ? (\n                  <div className=\"empty-state\">This seller has no active listings.</div>\n                ) : (\n                  profile.listings.map((listing) => <ListingCard key={listing.id} listing={listing} />)\n                )}\n              </div>\n            </div>\n          </div>\n        ) : null}\n      </section>\n    </main>\n  );\n}\n\nexport default UserProfile;\n","import React, { useState } from 'react';\nimport { useHistory } from 'react-router-dom';\nimport { loginAccount, registerAccount, storeSession } from '../utils';\n\nconst initialLogin = {\n  email: '',\n  password: '',\n};\n\nconst initialSignup = {\n  username: '',\n  email: '',\n  password: '',\n  school: '',\n  region: '',\n  area: '',\n  campus: '',\n  bio: '',\n};\n\nfunction Auth({ onLogin }) {\n  const history = useHistory();\n  const [loginForm, setLoginForm] = useState(initialLogin);\n  const [signupForm, setSignupForm] = useState(initialSignup);\n  const [loginError, setLoginError] = useState('');\n  const [signupError, setSignupError] = useState('');\n  const [signupStatus, setSignupStatus] = useState('');\n\n  async function handleLogin(event) {\n    event.preventDefault();\n    setLoginError('');\n\n    try {\n      const user = await loginAccount(loginForm);\n      storeSession(user);\n      onLogin(user);\n      history.push('/listings');\n    } catch (error) {\n      setLoginError(error.response?.data?.message || 'Unable to log in.');\n    }\n  }\n\n  async function handleSignup(event) {\n    event.preventDefault();\n    setSignupError('');\n    setSignupStatus('');\n\n    try {\n      const user = await registerAccount(signupForm);\n      storeSession(user);\n      onLogin(user);\n      setSignupForm(initialSignup);\n      setSignupStatus('Account created. You are now signed in.');\n      history.push('/profile');\n    } catch (error) {\n      setSignupError(error.response?.data?.message || 'Unable to create account.');\n    }\n  }\n\n  return (\n    <main className=\"page\">\n      <section className=\"auth-grid\">\n        <div className=\"panel section\">\n          <span className=\
,CAAEA,WAAY,CAAE,CAAC,CACjC,CAAC,EACF,CAAC,cACTI,0BAAA,CAACgK,iBAAM,GAAE,CAAC,EACP,CAAC,CACA,CAAC,CAEb,CAEeC,+CAAG,E;;;;;ACzClBQ,mBAAQ,CAACC,MAAM,cACb1K,0BAAA,CAAC2K,eAAK,CAACC,UAAU,EAAA7K,QAAA,cACfC,0BAAA,CAACiK,OAAG,GAAE,CAAC,CACS,CAAC,CACnBY,QAAQ,CAACC,cAAc,CAAC,MAAM,CAChC,CAAC,C","file":"x","sourcesContent":["// extracted by mini-css-extract-plugin","import React from 'react';\nimport { Link } from 'react-router-dom';\n\nconst mockPhotos = {\n  food:\n    'https://images.unsplash.com/photo-1498837167922-ddd27525d352?auto=format&fit=crop&w=1200&q=80',\n  appliance:\n    'https://images.unsplash.com/photo-1484154218962-a197022b5858?auto=format&fit=crop&w=1200&q=80',\n  campus:\n    'https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=1200&q=80',\n};\n\nfunction Home({ currentUser }) {\n  return (\n    <main className=\"page\">\n      <section className=\"apple-hero\">\n        <div className=\"hero-orb hero-orb-left\" />\n        <div className=\"hero-orb hero-orb-right\" />\n        <div className=\"hero-content reveal-up\">\n          <span className=\"eyebrow\">Campus reuse platform</span>\n          <h1>CampusCycle makes local reuse feel simple, credible, and immediate.</h1>\n          <p className=\"lede\">\n            A refined marketplace for students to circulate appliances, dorm essentials, and everyday goods before they\n            turn into avoidable waste.\n          </p>\n          <div className=\"button-row hero-actions\">\n            <Link className=\"button\" to=\"/listings\">\n              Browse listings\n            </Link>\n            {currentUser ? (\n              <Link className=\"button-secondary\" to=\"/profile\">\n                View your profile\n              </Link>\n            ) : (\n              <Link className=\"button-secondary\" to=\"/auth\">\n                Create account\n              </Link>\n            )}\n          </div>\n        </div>\n        <div className=\"hero-device reveal-up delay-1\">\n          <div className=\"device-shell\">\n            <div className=\"device-glow\" />\n            <div className=\"device-screen\">\n              <div className=\"device-status\">CampusCycle</div>\n              <div className=\"device-card featured-card\">\n                <span className=\"tag\">Reuse in action</span>\n                <strong>Mini fridge</strong>\n                <p>Collected in Harvard Square and kept in use instead of discarded at move-out.</p>\n              </div>\n              <div className=\"device-grid\">\n                <div className=\"device-card\">\n                  <span className=\"mini-label\">School</span>\n                  <strong>Harvard</strong>\n                </div>\n                <div className=\"device-card\">\n                  <span className=\"mini-label\">Region</span>\n                  <strong>Greater Boston</strong>\n                </div>\n                <div className=\"device-card wide\">\n                  <span className=\"mini-label\">Purpose</span>\n                  <strong>Reduce food waste. Extend appliance life. Make student reuse visible.</strong>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section className=\"story-intro reveal-up delay-2\">\n        <span className=\"eyebrow\">Why it matters</span>\n        <h2 className=\"section-title\">A professional marketplace informed by environmental education.</h2>\n        <p className=\"lede narrow\">\n          When students move quickly, usable fridges, cookware, storage, and unopened food are often left behind.\n          CampusCycle reframes that transition as an opportunity for reuse, affordability, and better environmental\n          decision-making.\n        </p>\n      </section>\n\n      <section className=\"photo-story-grid\">\n        <article className=\"photo-story-card reveal-up\">\n          <img className=\"story-photo\" src={mockPhotos.food} alt=\"Fresh groceries and produce on a table\" />\n          <div className=\"photo-story-copy\">\n            <span className=\"eyebrow\">Food systems</span>\n            <h3>Usable food should support students, not become avoidable waste.</h3>\n            <p>\n              A significant share of move-out waste comes from unopened or lightly used groceries. Pantry exchanges,\n              shared meal supplies, and coordinated pickup can turn disposal into access.\n            </p>\n          </div>\n        </article>\n        <article className=\"photo-story-card reveal-up delay-1\">\n          <img className=\"story-photo\" src={mockPhotos.appliance} alt=\"A compact kitchen with reusable appliances\" />\n          <div className=\"photo-story-copy\">\n            <span className=\"eyebrow\">Appliance reuse</span>\n            <h3>Durable appliances should stay in circulation longer.</h3>\n            <p>\n              Small appliances are often abandoned because resale feels inconvenient. A more polished marketplace changes\n              that behavior by making local reuse faster, clearer, and more trustworthy.\n            </p>\n          </div>\n        </article>\n      </section>\n\n      <section className=\"impact-grid\">\n        <article className=\"impact-panel reveal-up\">\n          <span className=\"eyebrow\">Food waste</span>\n          <h3>Surplus groceries can become shared value.</h3>\n          <p>\n            End-of-semester transitions often leave students with unopened pantry items, meal ingredients, and kitchen\n            basics they cannot carry home. A local exchange model helps keep those resources in active use.\n          </p>\n        </article>\n        <article className=\"impact-panel reveal-up delay-1\">\n          <span className=\"eyebrow\">Appliance waste</span>\n          <h3>Useful appliances should not be treated as disposable.</h3>\n          <p>\n            Mini fridges, lamps, fans, kettles, and microwaves are costly to replace and inefficient to discard.\n            Extending their life, even briefly, can reduce both waste and student expense.\n          </p>\n        </article>\n      </section>\n\n      <section className=\"insight-stage\">\n        <div className=\"insight-copy reveal-up\">\n          <span className=\"eyebrow\">Educational dashboard</span>\n          <h2 className=\"section-title\">Give each listing a clearer sustainability context.</h2>\n          <p className=\"lede narrow\">\n            Environmental messaging is more effective when it is specific. These mock visuals translate everyday campus\n            behavior into simple signals that make reuse feel practical, local, and measurable.\n          </p>\n        </div>\n        <div className=\"insight-grid\">\n          <article className=\"chart-panel reveal-up\">\n            <div className=\"chart-header\">\n              <span className=\"mini-label\">Mock weekly diversion</span>\n              <strong>Items redirected from waste</strong>\n            </div>\n            <div className=\"bar-chart\">\n              <div className=\"bar-group\">\n                <span className=\"bar-label\">Food</span>\n                <div className=\"bar-track\">\n                  <div className=\"bar-fill bar-food\" style={{ width: '72%' }} />\n                </div>\n                <span className=\"bar-value\">72%</span>\n              </div>\n              <div className=\"bar-group\">\n                <span className=\"bar-label\">Appliances</span>\n                <div className=\"bar-track\">\n                  <div className=\"bar-fill bar-appliance\" style={{ width: '61%' }} />\n                </div>\n                <span className=\"bar-value\">61%</span>\n              </div>\n              <div className=\"bar-group\">\n                <span className=\"bar-label\">Storage</span>\n                <div className=\"bar-track\">\n                  <div className=\"bar-fill bar-storage\" style={{ width: '84%' }} />\n                </div>\n                <span className=\"bar-value\">84%</span>\n              </div>\n            </div>\n          </article>\n          <article className=\"chart-panel chart-panel-dark reveal-up delay-1\">\n            <div className=\"chart-header\">\n              <span className=\"mini-label\">Mock semester trend</span>\n              <strong>Participation improves when reuse is visible</strong>\n            </div>\n            <div className=\"line-chart\" aria-hidden=\"true\">\n              <div className=\"line-grid\" />\n              <div className=\"line-curve\" />\n              <div className=\"line-point point-one\" />\n              <div className=\"line-point point-two\" />\n              <div className=\"line-point point-three\" />\n              <div className=\"line-point point-four\" />\n            </div>\n            <p className=\"muted chart-caption\">\n              Mock data: when reuse activity is easy to see, educational messaging becomes more actionable.\n            </p>\n          </article>\n        </div>\n      </section>\n\n      <section className=\"education-band\">\n        <div className=\"education-copy reveal-up\">\n          <span className=\"eyebrow\">Educational focus</span>\n          <h2 className=\"section-title\">Support better habits at the exact moment students need them.</h2>\n          <p className=\"lede narrow\">\n            The most effective sustainability tools are practical. Instead of relying on abstract messaging, CampusCycle\n            makes reuse visible through nearby listings, regional pickup, trust cues, and a clearer handoff experience.\n          </p>\n        </div>\n        <div className=\"education-metrics reveal-up delay-1\">\n          <div className=\"metric-card\">\n            <strong>Reuse first</strong>\n            <span>Guide student decisions toward keeping useful goods in circulation.</span>\n          </div>\n          <div className=\"metric-card\">\n            <strong>Regional pickup</strong>\n            <span>School, region, and area filters make local reuse feel immediate.</span>\n          </div>\n          <div className=\"metric-card\">\n            <strong>Visible impact</strong>\n            <span>Each listing can communicate the practical value of avoiding unnecessary disposal.</span>\n          </div>\n        </div>\n      </section>\n\n      <section className=\"campaign-grid\">\n        <article className=\"campaign-photo reveal-up\">\n          <img className=\"campaign-image\" src={mockPhotos.campus} alt=\"Students walking through a campus setting\" />\n        </article>\n        <article className=\"campaign-copy reveal-up delay-1\">\n          <span className=\"eyebrow\">Design rationale</span>\n          <h2 className=\"section-title\">A calmer visual system builds more trust.</h2>\n          <p className=\"lede\">\n            The green-led palette signals environmental purpose and trust. Soft neutrals keep the interface premium.\n            Generous white space reduces friction. Together, those decisions make the platform feel more like a student\n            service and less like an informal classifieds board.\n          </p>\n          <div className=\"campaign-points\">\n            <div className=\"campaign-point\">\n              <strong>Green-led action</strong>\n              <span>Primary actions communicate growth, care, and environmental responsibility.</span>\n            </div>\n            <div className=\"campaign-point\">\n              <strong>Calm neutral surfaces</strong>\n              <span>Soft backgrounds create a more stable reading experience in educational sections.</span>\n            </div>\n            <div className=\"campaign-point\">\n              <strong>Data with context</strong>\n              <span>Charts, photography, and concise copy help make the mission feel tangible.</span>\n            </div>\n          </div>\n        </article>\n      </section>\n\n      <section className=\"cta-banner reveal-up\">\n        <span className=\"eyebrow\">Start locally</span>\n        <h2 className=\"section-title\">Built for campus communities that want lower waste and better handoffs.</h2>\n        <div className=\"button-row\">\n          <Link className=\"button\" to=\"/listings\">\n            Browse listings\n          </Link>\n          <Link className=\"button-secondary\" to=\"/checkout\">\n            View mock checkout\n          </Link>\n        </div>\n      </section>\n    </main>\n  );\n}\n\nexport default Home;\n","import axios from 'axios';\n\nconst API_BASE_URL = 'http://localhost:5001/api';\nconst SESSION_KEY = 'campuscycle-session';\n\nexport const fetchListings = async (params = {}) => {\n  try {\n    const response = await axios.get(`${API_BASE_URL}/listings`, { params });\n    return response.data;\n  } catch (error) {\n    console.error('Error fetching listings:', error);\n    throw error;\n  }\n};\n\nexport const createListing = async (listingData) => {\n  try {\n    const response = await axios.post(`${API_BASE_URL}/listings`, listingData);\n    return response.data;\n  } catch (error) {\n    console.error('Error creating listing:', error);\n    throw error;\n  }\n};\n\nexport const fetchUserProfile = async (userId) => {\n  try {\n    const response = await axios.get(`${API_BASE_URL}/users/${userId}`);\n    return response.data;\n  } catch (error) {\n    console.error('Error fetching user profile:', error);\n    throw error;\n  }\n};\n\nexport const registerAccount = async (userData) => {\n  try {\n    const response = await axios.post(`${API_BASE_URL}/users`, userData);\n    return response.data;\n  } catch (error) {\n    console.error('Error creating account:', error);\n    throw error;\n  }\n};\n\nexport const loginAccount = async (credentials) => {\n  try {\n    const response = await axios.post(`${API_BASE_URL}/auth/login`, credentials);\n    return response.data;\n  } catch (error) {\n    console.error('Error logging in:', error);\n    throw error;\n  }\n};\n\nexport const getStoredSession = () => {\n  const stored = window.localStorage.getItem(SESSION_KEY);\n  return stored ? JSON.parse(stored) : null;\n};\n\nexport const storeSession = (user) => {\n  window.localStorage.setItem(SESSION_KEY, JSON.stringify(user));\n};\n\nexport const clearSession = () => {\n  window.localStorage.removeItem(SESSION_KEY);\n};\n\nexport const formatPrice = (price) => {\n  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(price);\n};\n","import React from 'react';\nimport { Link } from 'react-router-dom';\nimport { formatPrice } from '../utils';\n\nfunction ListingCard({ listing }) {\n  return (\n    <article className=\"listing-card\">\n      {listing.imageData ? (\n        <img className=\"listing-image\" src={listing.imageData} alt={listing.title} />\n      ) : (\n        <div className=\"listing-image listing-image-placeholder\">No photo uploaded</div>\n      )}\n      <div className=\"listing-meta\">\n        <span className=\"tag\">{listing.category}</span>\n        <span className=\"price-pill\">{formatPrice(listing.price)}</span>\n      </div>\n      <h3>{listing.title}</h3>\n      <p className=\"muted\">{listing.description}</p>\n      <div className=\"listing-meta\">\n        <span>{listing.location}</span>\n        <span>{listing.seller ? listing.seller.username : 'Unknown seller'}</span>\n      </div>\n      <p className=\"muted listing-region\">\n        {[listing.school, listing.region, listing.area].filter(Boolean).join(' • ')}\n      </p>\n      <div className=\"button-row listing-actions\">\n        <Link\n          className=\"button\"\n          to={{\n            pathname: '/checkout',\n            state: { listing },\n          }}\n        >\n          Buy now\n        </Link>\n      </div>\n    </article>\n  );\n}\n\nexport default ListingCard;\n","import React, { useEffect, useMemo, useState } from 'r